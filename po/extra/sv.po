#: data/desktop.metainfo.xml.in:10
msgid "Desktop Settings"
msgstr "Skrivbordsinställningar"

#: data/desktop.metainfo.xml.in:11
msgid "Configure the dock, hot corners, and change wallpaper"
msgstr "Ställ in dockan, aktiva hörn och byt bakgrundsbild"

#: data/desktop.metainfo.xml.in:40
msgid "elementary, Inc."
msgstr "elementary, Inc."

#: data/desktop.metainfo.xml.in:48 data/desktop.metainfo.xml.in:61
#: data/desktop.metainfo.xml.in:71 data/desktop.metainfo.xml.in:87
#: data/desktop.metainfo.xml.in:97 data/desktop.metainfo.xml.in:110
#: data/desktop.metainfo.xml.in:128 data/desktop.metainfo.xml.in:149
msgid "Other updates:"
msgstr "Övriga uppdateringar:"

#: data/desktop.metainfo.xml.in:50 data/desktop.metainfo.xml.in:64
#: data/desktop.metainfo.xml.in:74 data/desktop.metainfo.xml.in:90
#: data/desktop.metainfo.xml.in:99 data/desktop.metainfo.xml.in:116
#: data/desktop.metainfo.xml.in:134 data/desktop.metainfo.xml.in:152
msgid "Updated translations"
msgstr "Uppdaterade översättningar"

#: data/desktop.metainfo.xml.in:63
msgid "Update dock style"
msgstr "Uppdatera dockstilen"

#: data/desktop.metainfo.xml.in:73
msgid "Add setting for fullscreen hotcorners"
msgstr "Lägg till inställning för aktiva hörn i helskärm"

#: data/desktop.metainfo.xml.in:89
msgid "Add setting for scroll to switch workspaces"
msgstr "Lägg till inställning för rullning för byte av arbetsyta"

#: data/desktop.metainfo.xml.in:106
msgid "New Features:"
msgstr "Nya funktioner:"

#: data/desktop.metainfo.xml.in:108
msgid "Always Show Scrollbars setting"
msgstr "Visa alltid inställning för rullningslister"

#: data/desktop.metainfo.xml.in:112
msgid "Redundant labels have been cleaned up on the Appearance tab"
msgstr "Överflödiga etiketter har rensats upp på fliken Utseende"

#: data/desktop.metainfo.xml.in:113
msgid "The Dim Wallpaper setting has moved to the Appearance tab"
msgstr "Inställningen Dämpa bakgrundsbild har flyttats till fliken Utseende"

#: data/desktop.metainfo.xml.in:114
msgid ""
"The style selector now shows of a preview of your wallpaper as well as "
"previewing the dim setting"
msgstr ""
"Stilväljaren visar nu en förhandsgranskning av din bakgrundsbild samt en "
"förhandsgranskning av dämpningsinställningen"

#: data/desktop.metainfo.xml.in:115
msgid "Improved screen reader accessibility"
msgstr "Förbättrad tillgänglighet för skärmläsare"

#: data/desktop.metainfo.xml.in:130
msgid "Redesign Dock & Panel settings with helpful description text"
msgstr "Omarbeta dock- och panelinställningarna med användbar beskrivningstext"

#: data/desktop.metainfo.xml.in:131
msgid "Show or hide optional panel indicators"
msgstr "Visa eller dölja valfria panelindikatorer"

#: data/desktop.metainfo.xml.in:132
msgid ""
"Fix translation of slideshow delay value and \"Dim with dark style\" label"
msgstr ""
"Rätt översättning av värdet för fördröjning av bildspel och etiketten "
"\"Dämpa med mörk stil\""

#: data/desktop.metainfo.xml.in:133
msgid ""
"Fix an issue where wallpapers were not removed when closing System Settings "
"immediately after"
msgstr ""
"Åtgärdat ett problem där bakgrundsbilder inte togs bort när "
"Systeminställningar stängdes omedelbart efter"

#: data/desktop.metainfo.xml.in:145
msgid "New features:"
msgstr "Nya funktioner:"

#: data/desktop.metainfo.xml.in:147
msgid "Add an option to dim wallpapers when dark style is active"
msgstr ""
"Lägg till ett alternativ för att dämpa bakgrundsbilder när mörk stil är aktiv"

#: data/desktop.metainfo.xml.in:151
msgid "Use a more vertical layout in the Text view"
msgstr "Använd en mer vertikal layout i textvyn"
